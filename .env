# Copy this file to .env for local development and fill in the value.
# In Vercel: Project Settings -> Environment Variables -> add VITE_API_URL
# pointing at your Railway backend's public URL (NO trailing slash), e.g.
#   VITE_API_URL=https://k25-backend-production.up.railway.app
VITE_API_URL=https://diplomatic-manifestation-production.up.railway.app
